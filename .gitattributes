# Normalise line endings: LF in repo, native in working copy.
* text=auto eol=lf

# Binary files (don't try to diff or alter).
*.png binary
*.jpg binary
*.gif binary
*.sqlite binary
*.db binary
*.ico binary

# Keep Windows scripts CRLF in working copies on Windows so they execute.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
