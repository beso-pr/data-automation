<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>ETL Pipeline Report — {{ generated_at }}</title>
<style>
  :root {
    --bg: #0f172a; --panel: #1e293b; --ink: #e2e8f0; --muted: #94a3b8;
    --accent: #38bdf8; --good: #4ade80; --warn: #f59e0b; --bad: #f87171;
    --border: #334155; --track: rgba(148, 163, 184, 0.12);
  }
  * { box-sizing: border-box; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    margin: 0; padding: 32px; background: var(--bg); color: var(--ink); line-height: 1.5;
  }
  .container { max-width: 1280px; margin: 0 auto; }
  header { margin-bottom: 32px; }
  h1 { margin: 0 0 4px; font-size: 28px; }
  h2 { margin-top: 36px; font-size: 20px; border-bottom: 1px solid var(--border); padding-bottom: 6px; }
  .muted { color: var(--muted); font-size: 13px; }

  /* KPI tiles */
  .kpi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-top: 16px; }
  .kpi {
    background: var(--panel); padding: 18px 20px; border-radius: 10px;
    border: 1px solid var(--border);
  }
  .kpi .label { font-size: 12px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; }
  .kpi .value { font-size: 24px; font-weight: 600; margin-top: 4px; font-variant-numeric: tabular-nums; }
  .kpi .sub { font-size: 12px; color: var(--muted); margin-top: 2px; }

  /* Tables */
  table {
    width: 100%; border-collapse: collapse; margin-top: 12px; background: var(--panel);
    border-radius: 8px; overflow: hidden; font-size: 14px; table-layout: fixed;
  }
  th, td {
    padding: 10px 14px; text-align: left; border-bottom: 1px solid var(--border);
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap; vertical-align: middle;
  }
  th {
    background: #0b1220; color: var(--muted); font-weight: 600;
    text-transform: uppercase; font-size: 11px; letter-spacing: 0.04em;
  }
  tr:last-child td { border-bottom: none; }
  td.num, th.num { text-align: right; font-variant-numeric: tabular-nums; }
  td.dim { color: var(--muted); }

  /* Inline bar chart inside a cell: number on the right, sparkline filling the rest */
  .bar-row {
    display: flex; align-items: center; gap: 12px;
  }
  .bar-row .bar-value {
    flex: 0 0 auto; min-width: 92px; text-align: right;
    font-variant-numeric: tabular-nums;
  }
  .bar-row .bar-track {
    flex: 1; height: 6px; background: var(--track); border-radius: 3px; overflow: hidden;
    order: -1; /* track on the LEFT, number on the right */
  }
  .bar-row .bar-fill {
    display: block; height: 100%; background: var(--accent); border-radius: 3px;
  }

  /* Pills for z-scores */
  .pill { display: inline-block; padding: 2px 8px; border-radius: 999px; font-size: 11px; font-weight: 600; font-variant-numeric: tabular-nums; }
  .pill.up   { background: rgba(74,222,128,0.15); color: var(--good); }
  .pill.down { background: rgba(248,113,113,0.15); color: var(--bad); }

  /* Correlation strength colouring */
  .corr-pos { color: var(--good); }
  .corr-neg { color: var(--bad); }

  footer { margin-top: 48px; color: var(--muted); font-size: 12px; text-align: center; }
</style>
</head>
<body>
<div class="container">

<header>
  <h1>Multi-API ETL — Sales Report</h1>
  <div class="muted">
    Generated {{ generated_at }} • Base currency: <strong>{{ base_currency }}</strong>
    • Range: {{ date_range[0] }} → {{ date_range[1] }}
  </div>
</header>

<section>
  <div class="kpi-grid">
    <div class="kpi"><div class="label">Total Revenue</div><div class="value">{{ kpis.total_revenue }}</div><div class="sub">{{ base_currency }}</div></div>
    <div class="kpi"><div class="label">Total Units</div><div class="value">{{ kpis.total_units }}</div></div>
    <div class="kpi"><div class="label">Orders</div><div class="value">{{ kpis.num_orders }}</div></div>
    <div class="kpi"><div class="label">Avg Order Value</div><div class="value">{{ kpis.avg_order_value }}</div><div class="sub">{{ base_currency }}</div></div>
    <div class="kpi"><div class="label">Cities</div><div class="value">{{ kpis.num_cities }}</div></div>
    <div class="kpi"><div class="label">Anomalies Flagged</div><div class="value">{{ kpis.num_anomalies }}</div><div class="sub">|z| ≥ 2.0</div></div>
  </div>
</section>

<section>
  <h2>Daily totals</h2>
  <table>
    <colgroup>
      <col style="width: 12%">
      <col style="width: 44%">
      <col style="width: 12%">
      <col style="width: 12%">
      <col style="width: 20%">
    </colgroup>
    <thead>
      <tr>
        <th>Date</th>
        <th class="num">Revenue ({{ base_currency }})</th>
        <th class="num">Units</th>
        <th class="num">Orders</th>
        <th class="num">Avg Order Value</th>
      </tr>
    </thead>
    <tbody>
    {% for row in daily %}
      <tr>
        <td>{{ row.date }}</td>
        <td class="num">
          <div class="bar-row">
            <div class="bar-track"><span class="bar-fill" style="width: {{ row.bar_pct }}%"></span></div>
            <span class="bar-value">{{ "{:,.2f}".format(row.total_revenue_base) }}</span>
          </div>
        </td>
        <td class="num">{{ "{:,}".format(row.total_units) }}</td>
        <td class="num">{{ row.num_orders }}</td>
        <td class="num">{{ "{:,.2f}".format(row.avg_order_value_base) }}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
</section>

<section>
  <h2>Revenue by country</h2>
  <table>
    <colgroup>
      <col style="width: 18%">
      <col style="width: 28%">
      <col style="width: 18%">
      <col style="width: 18%">
      <col style="width: 18%">
    </colgroup>
    <thead>
      <tr>
        <th>Country</th>
        <th class="num">Revenue ({{ base_currency }})</th>
        <th class="num">Units</th>
        <th class="num">Orders</th>
        <th class="num">Share</th>
      </tr>
    </thead>
    <tbody>
    {% for row in country %}
      <tr>
        <td>{{ row.country }}</td>
        <td class="num">{{ "{:,.2f}".format(row.total_revenue_base) }}</td>
        <td class="num">{{ "{:,}".format(row.total_units) }}</td>
        <td class="num">{{ row.num_orders }}</td>
        <td class="num">{{ "{:.1%}".format(row.share) }}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
</section>

<section>
  <h2>City performance &amp; weather</h2>
  <table>
    <colgroup>
      <col style="width: 18%">
      <col style="width: 12%">
      <col style="width: 22%">
      <col style="width: 14%">
      <col style="width: 17%">
      <col style="width: 17%">
    </colgroup>
    <thead>
      <tr>
        <th>City</th>
        <th>Country</th>
        <th class="num">Revenue ({{ base_currency }})</th>
        <th class="num">Units</th>
        <th class="num">Avg Temp (°C)</th>
        <th class="num">Avg Precip (mm)</th>
      </tr>
    </thead>
    <tbody>
    {% for row in city %}
      <tr>
        <td>{{ row.city }}</td>
        <td class="dim">{{ row.country }}</td>
        <td class="num">{{ "{:,.2f}".format(row.total_revenue_base) }}</td>
        <td class="num">{{ "{:,}".format(row.total_units) }}</td>
        <td class="num">{{ "—" if row.avg_temp_c is none else "{:.1f}".format(row.avg_temp_c) }}</td>
        <td class="num">{{ "—" if row.avg_precip_mm is none else "{:.1f}".format(row.avg_precip_mm) }}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
</section>

{% if anomalies %}
<section>
  <h2>Anomalies (city-day revenue, |z| ≥ 2.0)</h2>
  <table>
    <colgroup>
      <col style="width: 16%">
      <col style="width: 24%">
      <col style="width: 14%">
      <col style="width: 26%">
      <col style="width: 20%">
    </colgroup>
    <thead>
      <tr>
        <th>Date</th>
        <th>City</th>
        <th>Country</th>
        <th class="num">Revenue ({{ base_currency }})</th>
        <th class="num">Z-score</th>
      </tr>
    </thead>
    <tbody>
    {% for row in anomalies %}
      <tr>
        <td>{{ row.date }}</td>
        <td>{{ row.city }}</td>
        <td class="dim">{{ row.country }}</td>
        <td class="num">{{ "{:,.2f}".format(row.amount_base) }}</td>
        <td class="num">
          <span class="pill {% if row.z_score >= 0 %}up{% else %}down{% endif %}">
            {{ "{:+.2f}".format(row.z_score) }}
          </span>
        </td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
</section>
{% endif %}

{% if correlations %}
<section>
  <h2>Weather ↔ Revenue correlation (per city)</h2>
  <table>
    <colgroup>
      <col style="width: 28%">
      <col style="width: 18%">
      <col style="width: 27%">
      <col style="width: 27%">
    </colgroup>
    <thead>
      <tr>
        <th>City</th>
        <th class="num">Sample size</th>
        <th class="num">Temp vs revenue</th>
        <th class="num">Precip vs revenue</th>
      </tr>
    </thead>
    <tbody>
    {% for row in correlations %}
      <tr>
        <td>{{ row.city }}</td>
        <td class="num">{{ row.n }}</td>
        <td class="num">
          {%- if row.corr_temp_revenue is none -%}
            —
          {%- else -%}
            <span class="{{ 'corr-pos' if row.corr_temp_revenue >= 0 else 'corr-neg' }}">{{ "{:+.3f}".format(row.corr_temp_revenue) }}</span>
          {%- endif -%}
        </td>
        <td class="num">
          {%- if row.corr_precip_revenue is none -%}
            —
          {%- else -%}
            <span class="{{ 'corr-pos' if row.corr_precip_revenue >= 0 else 'corr-neg' }}">{{ "{:+.3f}".format(row.corr_precip_revenue) }}</span>
          {%- endif -%}
        </td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
</section>
{% endif %}

<footer>
  Built by the etl-pipeline package • Data sources: Frankfurter (FX), Open-Meteo (weather), local sales CSV
</footer>

</div>
</body>
</html>
